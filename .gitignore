# Gradle — cache and per-module outputs (like __pycache__ / dist/)
.gradle/
build/

# Gradle wrapper JAR is committed; ignore accidental duplicates elsewhere
!gradle/wrapper/gradle-wrapper.jar

# Daemon JVM toolchain pin — auto-regenerated by Studio's first sync
# (updateDaemonJvm task). Foojay download URLs go stale over years; let
# each machine refresh on first open.
gradle/gradle-daemon-jvm.properties

# Android Studio / IntelliJ (machine-specific IDE state)
.idea/
*.iml
captures/
.cxx/
.externalNativeBuild/

# Kotlin compiler session files
.kotlin/

# Cursor / local agent plans (optional team docs can live under docs/)
.cursor/

# Local SDK path (sdk.dir=...) — never commit
local.properties

# Keystores and signing secrets (never commit)
*.jks
*.keystore
keystore.properties

# Packaged app outputs (also under build/; listed explicitly for clarity)
*.apk
*.aab

# Profiling / heap dumps
*.hprof

# OS noise
.DS_Store
Thumbs.db
